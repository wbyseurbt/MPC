<launch>
    <!-- 独立电机测试：只需 USB-CAN + 目标电机，无需完整机器人配置 -->

    <!-- 同名 libdm_hw.so 若存在于其它 workspace（如 motor_ws），LD_LIBRARY_PATH 会优先加载那份，
         易出现 serial 符号未定义。此处把本工作空间 devel/lib 放在最前（find → …/devel/share/<pkg>）。 -->
    <env name="LD_LIBRARY_PATH" value="$(find legged_dm_hw)/../../lib:$(optenv LD_LIBRARY_PATH)" />

    <!-- 硬件配置：测试电机列表（motor_test.yaml）-->
    <rosparam file="$(find legged_dm_hw)/config/motor_test.yaml" command="load"/>

    <!-- 控制器配置：测试关节列表（motor_test_controllers.yaml）-->
    <rosparam file="$(find legged_dm_hw)/config/motor_test_controllers.yaml" command="load"/>

    <!-- 硬件接口 + 控制循环 -->
    <node name="legged_dm_hw" pkg="legged_dm_hw" type="legged_dm_hw"
          respawn="false" clear_params="true" output="screen"/>

    <!-- 自动加载并启动控制器 -->
    <node name="controller_spawner" pkg="controller_manager" type="spawner"
          output="screen" respawn="false"
          args="joint_state_controller dm_test_controller"/>
</launch>
