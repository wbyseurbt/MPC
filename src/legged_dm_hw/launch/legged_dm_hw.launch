<launch>
    <env name="LD_LIBRARY_PATH" value="$(find legged_dm_hw)/../../lib:$(optenv LD_LIBRARY_PATH)" />

    <arg name="robot_type" default="dm" doc="Robot type: [dm]"/>

    <param name="legged_robot_description" command="$(find xacro)/xacro $(find legged_dm_description)/urdf/dm.urdf
        robot_type:=$(arg robot_type) "/>

    <!-- Load motor config (dm_actuators, serials, damiao loop params) -->
    <rosparam file="$(find legged_dm_hw)/config/$(arg robot_type).yaml" command="load"/>

    <node name="legged_dm_hw" pkg="legged_dm_hw" type="legged_dm_hw"
          respawn="false" clear_params="true" output="screen"/>

    <!-- IMU driver -->
    <node pkg="dm_imu" type="dm_imu_node" name="dm_imu_node" required="true" output="screen">
        <param name="port"  type="string" value="/dev/ttyACM1"/>
        <param name="baud"  type="int"    value="921600"/>
    </node>
</launch>
